# ============================================================================
# Per-client environment. Copy to .env.local and fill in. NEVER commit .env*.
# ============================================================================

# --- Frontend (Vite). The anon key is public by design; RLS protects the data. ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ============================================================================
# --- Edge-function secrets. Set with `supabase secrets set KEY=value`, ---
# --- one per client project. These are NOT read from this file at runtime; ---
# --- this block only documents what each deployment needs. ---
# ============================================================================
# OPENAI_API_KEY=sk-...                 # required: the chat model (gpt-4o-mini)
# LOG_HMAC_SECRET=<random 32+ bytes>    # required: signs client-side log tokens
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co   # injected by Supabase automatically
# SUPABASE_SERVICE_ROLE_KEY=...         # injected by Supabase automatically
# TURNSTILE_SECRET_KEY=...              # optional: Cloudflare Turnstile CAPTCHA
# RESEND_API_KEY=...                    # optional: cost-alert emails
# ALERT_EMAIL=you@example.com           # optional: where cost alerts are sent
# ALERT_FROM_EMAIL=alerts@example.com   # optional: verified Resend sender
# LOGGING_ENABLED=true                  # optional: toggle verbose logging
